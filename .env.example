# 复制本文件为 .env 后填写真实值。.env 已在 .gitignore 中；切勿把真实密钥写进 .env.example 或提交到 Git。
#
# DeepSeek（筛选新闻必填）
DEEPSEEK_API_KEY=sk-your-key-here

# RSS（每日脚本；不设则用代码内默认值）
FEEDS_FILE=feeds.txt
MAX_ITEMS_PER_FEED=40
MAX_TOTAL_ITEMS_BEFORE_MODEL=80

# 可选：拉取 RSS 时的 HTTP User-Agent（部分站点会校验）
# RSS_USER_AGENT=deepseek_news/1.0 (your contact)

# 只保留「最近 N 小时」内有可靠发布时间的新闻（搜索 + RSS 均生效）
NEWS_MAX_AGE_HOURS=48
# 无解析日期时是否丢弃（1=丢弃，保证均在时间窗内；RSS 源常无日期时可改为 0）
NEWS_DROP_UNDATED=1

# SMTP — Gmail 示例（须开启两步验证 + 应用专用密码）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_ENCRYPTION=starttls
# 若需 SSL 直连：SMTP_ENCRYPTION=ssl 且 SMTP_PORT=465
SMTP_USER=your@gmail.com
# 16 位应用专用密码：去掉空格，或用双引号保留空格
SMTP_PASSWORD=xxxxxxxxxxxxxxxx
EMAIL_FROM=your@gmail.com
# 多个收件人用英文逗号分隔
EMAIL_TO=your@gmail.com

# ========== SerpAPI（免费档每月约 250 次 search，以控制台为准）==========
# SERPAPI_API_KEY=paste_your_key_from_https://serpapi.com/manage-api-key
# NEWS_SEARCH_PROVIDER=serpapi
NEWS_SEARCH_MAX_RESULTS=15
# 可选：追加到搜索词后，扩大政策/监管类召回（不需要可注释）
# NEWS_SEARCH_QUERY_SUFFIX="OR 药监局 OR 国家医保局 OR 医疗信息化 OR 人工智能"
# SerpAPI：q 追加 after:YYYY-MM-DD（按 NEWS_MAX_AGE_HOURS）；遇 400 勿开 SERPAPI_SORT_DATE
NEWS_QUERY_APPEND_WHEN_2D=1
# SERPAPI_SORT_DATE=1
# SERPAPI_HL=zh-cn
# SERPAPI_GL=cn
# NEWS_SEARCH_QUERY=中国 医药 人工智能 数字化

# ========== 海外独立搜索（可选；不设则不抓海外分区）==========
# 与国内 NEWS_SEARCH_QUERY 分开；仅保留美国/欧洲/亚太语境下、模型判定为「高优先级」的条目。
# NEWS_INTL_SEARCH_QUERY=pharmaceutical biotechnology medical device artificial intelligence digital transformation
# NEWS_INTL_SEARCH_MAX_RESULTS=15
# 国际 SerpAPI 语言/地区（与国内 SERPAPI_HL / SERPAPI_GL 独立，避免 gl=cn 偏中国稿）
# NEWS_INTL_SERPAPI_HL=en
# NEWS_INTL_SERPAPI_GL=us
# 仅追加到「国际」query 后（不会自动拼国内 NEWS_SEARCH_QUERY_SUFFIX）
# NEWS_INTL_SEARCH_QUERY_SUFFIX="OR FDA OR EMA OR digital therapeutics"
# 海外合并后模型输出条数上限（默认 18）
# NEWS_INTL_HIGH_CAP=18

# ========== Tavily（与 SerpAPI 二选一或显式 NEWS_SEARCH_PROVIDER）==========
# NEWS_SEARCH_PROVIDER=tavily
# TAVILY_API_KEY=tvly-...
# TAVILY_TOPIC=news
# TAVILY_SEARCH_DEPTH=basic
# TAVILY_TIME_RANGE=d

# ========== GitHub Actions 云端定时（笔记本可关机）==========
# 将仓库推送到 GitHub 后，在仓库 Settings → Secrets → Actions 新建密钥：
#   名称：DIGEST_DOTENV
#   值：本机 .env 全文（多行粘贴）
# 工作流见 .github/workflows/daily-digest.yml；若仍保留本机 launchd，请运行 scripts/uninstall_macos_launchd.sh 以免每天两封邮件。
